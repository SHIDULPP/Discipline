<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alarm_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/alarm_icon_circle">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:contentDescription="@string/alarm_screen_title"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:tint="@color/alarm_accent" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.12"
            android:text="@string/alarm_screen_title"
            android:textAllCaps="true"
            android:textColor="@color/alarm_secondary_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.08"
            android:text="@string/alarm_elapsed_label"
            android:textAllCaps="true"
            android:textColor="@color/alarm_accent"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/alarm_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="00:00"
            android:textColor="@color/alarm_primary_text"
            android:textSize="52sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/alarm_card_background"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/alarm_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/alarm_primary_text"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alarm_subheading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/alarm_secondary_text"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_done"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/alarm_btn_primary"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="@string/alarm_done"
                android:textAllCaps="false"
                android:textColor="@color/alarm_accent_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_snooze"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/alarm_btn_snooze"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="@string/alarm_snooze"
                android:textAllCaps="false"
                android:textColor="@color/alarm_primary_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/alarm_btn_continue"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="@string/alarm_continue"
                android:textAllCaps="false"
                android:textColor="@color/alarm_secondary_text"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
